#!/bin/sh
# Quiztin — enforce Conventional Commits on the summary line.
# One-time setup per clone: git config core.hooksPath .githooks
first_line=$(head -n1 "$1")

# Allow merge/revert/fixup summaries through.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|refactor|chore|docs|test|build|perf)(\([a-z0-9./_-]+\))?!?: .+'
if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

echo "✗ Commit message must follow Conventional Commits:" >&2
echo "    <type>(<optional scope>): <imperative summary>" >&2
echo "  types: feat fix refactor chore docs test build perf" >&2
echo "  got:  $first_line" >&2
exit 1
